# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# Security: replace in every deployed environment
SECRET_KEY=change-me-local-secret
JWT_SECRET_KEY=change-me-local-jwt-secret

# Database
DEV_DATABASE_URI=postgresql://assistencias_dev:assistencias_dev@localhost:5432/assistencias_dev
TEST_DATABASE_URI=postgresql://assistencias_test:assistencias_test@localhost:5432/assistencias_test
DATABASE_URI=postgresql://assistencias_dev:assistencias_dev@localhost:5432/assistencias_dev
DATABASE_URL=

# CORS: comma-separated allowed origins. Production should be explicit.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Uploads
UPLOAD_FOLDER=api/static/uploads
MAX_CONTENT_LENGTH=16777216

# Business defaults
EMPRESA_LATITUDE=-24.465241
EMPRESA_LONGITUDE=-53.952700
CUSTO_POR_KM=2.00

# SolarZ integration
SOLARZ_BASE_URL=https://app.solarz.com.br
SOLARZ_USERNAME=usuario@example.com
SOLARZ_PASSWORD=change-me
SOLARZ_PAGE_SIZE=100

# Backup/restore scripts
BACKUP_DIR=backups
PGPASSWORD=
